<div class="row justify-content-center px-2">
  <div class="col-12 col-sm-8 col-md-5 col-lg-4">
    <div class="card shadow-sm border-0">
      <div class="card-body p-4">
        <h3 class="text-center mb-4 fw-bold">Login</h3>
        
        <%= form_with url: login_path, local: true, data: { turbo: false } do |form| %>
          <div class="mb-3">
            <%= form.label :email, class: "form-label text-muted small uppercase" %>
            <%= form.email_field :email, class: "form-control form-control-lg", required: true, placeholder: "email@example.com" %>
          </div>
          
          <div class="mb-4">
            <%= form.label :password, class: "form-label text-muted small uppercase" %>
            <%= form.password_field :password, class: "form-control form-control-lg", required: true %>
          </div>
          
          <%= form.submit "Login", class: "btn btn-primary btn-lg w-100 shadow-sm" %>
        <% end %>
      </div>
    </div>
    <p class="text-center mt-3 text-muted small">
      &copy; <%= Time.current.year %> Salary Manager
    </p>
  </div>
</div>