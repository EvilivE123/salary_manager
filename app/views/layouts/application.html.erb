<!DOCTYPE html>
<html>
<head>
  <title>Salary Manager</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
</head>
<style>
  .flash-overlay {
    position: absolute;
    z-index: 1050; /* Higher than other elements to ensure it sits on top */
    width: 100%;
    max-width: 100%; /* Prevents the alert from being too wide on desktop */
  }

  /* Adjust for mobile screens */
  @media (max-width: 576px) {
    .flash-overlay {
      right: 0;
      left: 0;
      padding: 0 15px;
      max-width: 100%;
    }
  }
</style>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
    <div class="container">
    <button class="navbar-toggler border-0 px-1" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

      <a class="navbar-brand mx-auto mx-lg-0" href="/">Salary Manager</a>
      
      <!-- Navbar Links -->
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav me-auto">
          <% if logged_in? %>
            <li class="nav-item">
              <%= link_to 'Dashboard', dashboard_path, class: "nav-link #{'active' if current_page?(dashboard_path)}" %>
            </li>
            <% if admin? %>
              <li class="nav-item">
                <%= link_to 'Users', users_path, class: "nav-link #{'active' if current_page?(users_path)}" %>
              </li>
            <% end %>
          <% end %>
        </ul>
      </div>

      <!-- User Context -->
      <div class="d-flex align-items-center order-lg-last">
        <% if logged_in? %>
          <span class="navbar-text me-2 d-none d-sm-inline"><%= current_user.email %></span>
          <%= button_to 'Logout', logout_path, method: :delete, class: "btn btn-outline-light btn-sm" %>
        <% end %>
      </div>
    </div>
  </nav>

  <div class="container position-relative"> 
    <div id="flash-messages" class="flash-overlay" data-controller="flash">
      <% flash.each do |type, msg| %>
        <div class="alert alert-<%= type == 'notice' ? 'success' : 'danger' %> alert-dismissible fade show shadow">
          <%= msg %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% end %>
    </div> 
    <%= yield %>
  </div>
</body>
</html>